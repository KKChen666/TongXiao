# ===== TongXiao 环境变量 =====
# cp .env.example .env  然后编辑填入实际值

# GitHub 仓库地址（公开仓库用 https，私有仓库加 GIT_TOKEN）
GIT_REPO_URL=https://github.com/你的用户名/TongXiao.git
GIT_BRANCH=master
# GitHub Token（仅私有仓库需要: https://github.com/settings/tokens → 勾选 repo）
GIT_TOKEN=

# 数据库
DB_TYPE=mysql
MYSQL_HOST=119.45.182.166
MYSQL_PORT=9274
MYSQL_USER=TongXiao
MYSQL_PASSWORD=你的数据库密码
MYSQL_DATABASE=TongXiao

# 端口
SERVER_PORT=7896

# JWT 密钥（换成随机字符串）
JWT_SECRET=换成随机字符串

# ===== AI 模块配置 =====
# LLM API Key（必填）
OPENAI_API_KEY=你的LLM密钥
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MODEL_NAME=mimo-v2.5-pro

# 腾讯云 COS 对象存储（知识库文件上传）
COS_SECRET_ID=你的腾讯云SecretID
COS_SECRET_KEY=你的腾讯云SecretKey
COS_BUCKET=tongxiao-1385409028
COS_REGION=ap-nanjing

# 知识库管理页面 API Key（访问 /admin/knowledge 用）
KNOWLEDGE_ADMIN_KEY=换成你自己的密钥
